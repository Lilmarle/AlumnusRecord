<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.marler.alumnus.mapper.CollegeMapper">

    <!-- 查询所有学院 -->
    <select id="findAll" resultType="com.marler.alumnus.pojo.College">
        SELECT id, college_name AS collegeName, code, create_time AS createTime, update_time AS updateTime
        FROM college
        ORDER BY id ASC
    </select>

</mapper>
